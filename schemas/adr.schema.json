{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ADR Front Matter",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ADR-\\d{4}$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "superseded",
        "deprecated"
      ]
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "deciders": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "superseded_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "imports": {
          "type": "object",
          "properties": {
            "disallow": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "prefer": {
              "type": "array", 
              "items": {
                "type": "string"
              }
            }
          }
        },
        "boundaries": {
          "type": "object",
          "properties": {
            "layers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  }
                },
                "required": ["name"]
              }
            },
            "rules": {
              "type": "array",
              "items": {
                "type": "object", 
                "properties": {
                  "forbid": {
                    "type": "string"
                  }
                },
                "required": ["forbid"]
              }
            }
          }
        },
        "python": {
          "type": "object",
          "properties": {
            "disallow_imports": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "patterns": {
          "type": "object",
          "properties": {
            "patterns": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "language": {
                    "type": "string"
                  },
                  "rule": {
                    "oneOf": [
                      {"type": "string"},
                      {"type": "object"}
                    ]
                  },
                  "autofix": {
                    "type": "boolean"
                  },
                  "severity": {
                    "type": "string",
                    "enum": ["error", "warning", "info"]
                  }
                },
                "required": ["description", "rule"]
              }
            }
          }
        },
        "architecture": {
          "type": "object",
          "properties": {
            "layer_boundaries": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "rule": {
                    "type": "string"
                  },
                  "check": {
                    "type": "string"
                  },
                  "action": {
                    "type": "string",
                    "enum": ["block", "warn"]
                  },
                  "message": {
                    "type": "string"
                  }
                },
                "required": ["rule"]
              }
            },
            "required_structure": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                },
                "required": ["path"]
              }
            }
          }
        },
        "config_enforcement": {
          "type": "object",
          "properties": {
            "typescript": {
              "type": "object",
              "properties": {
                "tsconfig": {
                  "type": "object"
                }
              }
            },
            "python": {
              "type": "object",
              "properties": {
                "ruff": {
                  "type": "object"
                },
                "mypy": {
                  "type": "object"
                }
              }
            }
          }
        },
        "rationales": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}